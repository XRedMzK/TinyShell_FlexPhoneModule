FLEXPHONE_APP_NAME=FlexPhone Server
FLEXPHONE_DEBUG=true
FLEXPHONE_ALLOWED_ORIGINS=http://127.0.0.1:1420,http://localhost:1420,tauri://localhost,https://your-domain.example:25565

# Comma-separated list of STUN URLs.
FLEXPHONE_WEBRTC_STUN_URLS=stun:stun.l.google.com:19302

# Comma-separated list of TURN URLs (enable when coturn is running).
FLEXPHONE_WEBRTC_TURN_URLS=turn:127.0.0.1:3478?transport=udp,turn:127.0.0.1:3478?transport=tcp

# Preferred for production-like behavior: shared secret for ephemeral TURN credentials.
FLEXPHONE_WEBRTC_TURN_AUTH_SECRET=replace_with_shared_secret
FLEXPHONE_WEBRTC_TURN_AUTH_TTL_SECONDS=600
FLEXPHONE_WEBRTC_TURN_AUTH_CLOCK_SKEW_SECONDS=30
FLEXPHONE_WEBRTC_TURN_AUTH_USER_LABEL=flexphone

# Optional static fallback for local-only dev (leave empty when using TURN_AUTH_SECRET).
FLEXPHONE_WEBRTC_TURN_USERNAME=
FLEXPHONE_WEBRTC_TURN_PASSWORD=

# Set true to force relay-only ICE candidates for diagnostics.
FLEXPHONE_WEBRTC_FORCE_RELAY=false

# Auth challenge settings for Step 14.1.
FLEXPHONE_AUTH_CHALLENGE_TTL_SECONDS=60
FLEXPHONE_AUTH_CHALLENGE_NONCE_BYTES=32
FLEXPHONE_AUTH_CHALLENGE_REDIS_URL=redis://127.0.0.1:6379/0
FLEXPHONE_AUTH_CHALLENGE_STORE_PREFIX=auth:challenge
FLEXPHONE_AUTH_CHALLENGE_RETENTION_SECONDS=300
FLEXPHONE_AUTH_CLOCK_SKEW_SECONDS=30
FLEXPHONE_SIGNALING_REDIS_URL=redis://127.0.0.1:6379/0
FLEXPHONE_SIGNALING_PRESENCE_KEY_PREFIX=signaling:presence
FLEXPHONE_SIGNALING_SESSION_KEY_PREFIX=signaling:session
FLEXPHONE_SIGNALING_PUBSUB_CHANNEL_PREFIX=signaling:fanout
FLEXPHONE_SIGNALING_PRESENCE_TTL_SECONDS=45
FLEXPHONE_SIGNALING_INSTANCE_ID=flexphone-instance-1

# Auth JWT settings for Step 14.2.
FLEXPHONE_AUTH_JWT_ISSUER=flexphone-backend
FLEXPHONE_AUTH_JWT_AUDIENCE=signaling
FLEXPHONE_AUTH_JWT_ALGORITHM=HS256
FLEXPHONE_AUTH_JWT_TTL_SECONDS=600
FLEXPHONE_AUTH_JWT_SECRET=replace_with_strong_secret

# OpenTelemetry settings for Step 16.2.
FLEXPHONE_OTEL_EXPORTER=none
FLEXPHONE_OTEL_SERVICE_NAME=flexphone-backend
FLEXPHONE_OTEL_OTLP_ENDPOINT=http://127.0.0.1:4318/v1/traces
